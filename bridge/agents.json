{
  "agents": {
    "claude": {
      "command": "npx",
      "args": ["--yes", "@zed-industries/claude-code-acp@latest"],
      "displayName": "Claude Code"
    },
    "codex": {
      "command": "codex",
      "args": ["app-server", "--listen", "stdio://"],
      "displayName": "Codex",
      "appServerAdapter": true
    },
    "gemini": {
      "command": "npx",
      "args": ["--yes", "@google/gemini-cli@latest", "--experimental-acp"],
      "displayName": "Gemini"
    }
  }
}
