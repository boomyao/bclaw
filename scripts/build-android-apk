#!/usr/bin/env bash
# Build the Android debug APK and copy it to a stable distribution path.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_DIR="$(cd "${SCRIPT_DIR}/.." && pwd)"
OUT_DIR="${REPO_DIR}/dist"
APK_NAME="${BCLAW_APK_NAME:-bclaw-android-debug.apk}"

cd "$REPO_DIR"
./gradlew :app:assembleDebug

mkdir -p "$OUT_DIR"
cp "${REPO_DIR}/app/build/outputs/apk/debug/app-debug.apk" "${OUT_DIR}/${APK_NAME}"

printf '%s\n' "${OUT_DIR}/${APK_NAME}"
